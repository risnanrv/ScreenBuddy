<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- FontFamily -->
    <FontFamily x:Key="FontFamilyPrimary">Segoe UI, Inter, System-UI, sans-serif</FontFamily>

    <!-- Font Sizes -->
    <sys:Double x:Key="FontSizeCountdown" xmlns:sys="clr-namespace:System;assembly=mscorlib">88</sys:Double>
    <sys:Double x:Key="FontSizeMessage" xmlns:sys="clr-namespace:System;assembly=mscorlib">28</sys:Double>
    <sys:Double x:Key="FontSizeHeading" xmlns:sys="clr-namespace:System;assembly=mscorlib">18</sys:Double>
    <sys:Double x:Key="FontSizeSubheading" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <sys:Double x:Key="FontSizeBody" xmlns:sys="clr-namespace:System;assembly=mscorlib">15</sys:Double>
    <sys:Double x:Key="FontSizeCaption" xmlns:sys="clr-namespace:System;assembly=mscorlib">13</sys:Double>
    <sys:Double x:Key="FontSizeSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib">11</sys:Double>

</ResourceDictionary>
