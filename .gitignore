## Ignore Visual Studio / .NET build artifacts and user settings

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][In]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache folder
.vs/
.idea/

# NuGet Packages
*.nupkg
*.snupkg
**/packages/
!**/packages/repositories.config

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Crash logs & AppData persistent files
*.log
*.tmp
timer-state.json
config.json
